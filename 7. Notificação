public class Notificacao
{
    public string Mensagem { get; protected set; }

    public Notificacao(string mensagem)
    {
        this.Mensagem = mensagem;
    }

    public virtual string Enviar()
    {
        return Mensagem;
    }
}

public class Email : Notificacao
{
    public string EnderecoEmail { get; set; }

    public Email(string enderecoEmail, string mensagem) : base(mensagem)
    {
        EnderecoEmail = enderecoEmail;
    }

    public override string Enviar()
    {
         return base.Enviar();
    }
}

public class SMS : Notificacao
{
    public string Numero { get; set; }

    public SMS(string numero, string mensagem) : base(mensagem)
    {
        Numero = numero;
    }

    public override string Enviar()
    {
        return base.Enviar();
    }
}

